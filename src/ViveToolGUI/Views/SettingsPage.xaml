<Page
    x:Class="ViveToolGUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="40" Spacing="22">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
            <InfoBar x:Name="ResultBar" IsOpen="False" />

            <Border Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Administrator" FontSize="18" FontWeight="SemiBold" />
                    <ToggleSwitch x:Name="AlwaysAdminSwitch" Header="Always run as administrator" Toggled="AlwaysAdminSwitch_Toggled" />
                    <TextBlock x:Name="AdminStatusText" />
                    <Button Content="Restart as administrator" Click="RestartAdmin_Click" />
                </StackPanel>
            </Border>

            <Border Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="ViVeTool Runtime" FontSize="18" FontWeight="SemiBold" />
                    <RadioButtons x:Name="LocationModeButtons" SelectionChanged="LocationModeButtons_SelectionChanged">
                        <x:String>LocalAppData managed folder</x:String>
                        <x:String>Custom folder</x:String>
                    </RadioButtons>
                    <TextBox x:Name="CustomFolderBox" Header="Custom folder" PlaceholderText="D:\Tools\ViVeTool" TextChanged="CustomFolderBox_TextChanged" />
                    <CheckBox x:Name="ManageCustomFolderBox" Content="Allow app-managed updates in custom folder" Checked="ManageCustomFolderBox_Changed" Unchecked="ManageCustomFolderBox_Changed" />
                    <TextBlock x:Name="RuntimeStatusText" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Validate runtime" Click="ValidateRuntime_Click" />
                        <Button Content="Repair LocalAppData runtime" Click="RepairRuntime_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold" />
                    <ToggleSwitch x:Name="AutoToolUpdateSwitch" Header="Auto check ViVeTool updates" Toggled="AutoToolUpdateSwitch_Toggled" />
                    <ToggleSwitch x:Name="AutoDictionaryUpdateSwitch" Header="Auto check Dictionary updates" Toggled="AutoDictionaryUpdateSwitch_Toggled" />
                    <ComboBox x:Name="UpdateIntervalBox" Header="Update check interval" SelectedIndex="1" SelectionChanged="UpdateIntervalBox_SelectionChanged">
                        <ComboBoxItem Content="Daily" />
                        <ComboBoxItem Content="Weekly" />
                        <ComboBoxItem Content="Monthly" />
                    </ComboBox>
                    <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Check for ViVeTool Update" Click="CheckToolUpdate_Click" />
                        <Button Content="Apply Latest ViVeTool Update" Click="ApplyToolUpdate_Click" />
                        <Button Content="Check for Dictionary Update" Click="CheckDictionaryUpdate_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="20" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="About" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text=".NET 10, Windows App SDK 2.0.1, WinUI 3" />
                    <TextBlock Text="WebView2 is intentionally not included." Opacity="0.75" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
