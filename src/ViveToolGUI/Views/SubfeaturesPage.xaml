<Page
    x:Class="ViveToolGUI.Views.SubfeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="40" Spacing="18">
            <TextBlock Text="Subfeatures" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Query, add, delete, or notify feature usage subscriptions." Opacity="0.75" />
            <InfoBar x:Name="ResultBar" IsOpen="False" />

            <TextBox x:Name="FeatureBox" Header="Feature IDs or names" PlaceholderText="12345678 or TIFE" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <NumberBox x:Name="KindBox" Header="Reporting kind" Value="4" Minimum="0" Maximum="65535" />
                <NumberBox x:Name="OptionsBox" Grid.Column="1" Header="Reporting options" Value="1" Minimum="0" Maximum="65535" />
                <TextBox x:Name="TargetBox" Grid.Column="2" Header="Reporting target" PlaceholderText="0d83063ea3bdf875" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Query subscriptions" Click="Query_Click" />
                <Button Content="Add subscription" Click="Add_Click" />
                <Button Content="Delete subscription" Click="Delete_Click" />
                <Button Content="Notify usage" Click="Notify_Click" />
            </StackPanel>

            <TextBox x:Name="OutputBox" Header="Output" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="260" />
        </StackPanel>
    </ScrollViewer>
</Page>
